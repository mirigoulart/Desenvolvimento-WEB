# Variáveis de ambiente para envio de e-mail via SMTP
# Copie este arquivo para .env e preencha com suas credenciais

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS
CONTACT_EMAIL=
ALLOWED_ORIGIN=

